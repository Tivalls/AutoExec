return function(embeddedKey)
    local HttpService = game:GetService("HttpService") -- Get HttpService within this function's scope
    local FIREBASE_PROJECT_ID = "zyg-hub-v3-wl" -- Replace with your actual Firebase Project ID

    if not embeddedKey or embeddedKey == "" then
        warn("Key Checker: Received API key is empty.")
        return false
    end

    local databaseUrl = "https://" .. FIREBASE_PROJECT_ID .. "-default-rtdb.firebaseio.com/apiKeys/" .. embeddedKey .. ".json"
    local success, result = pcall(HttpService.RequestAsync, {
        Url = databaseUrl,
        Method = "GET"
    })

    if success and result.StatusCode == 200 then
        local response = HttpService:JSONDecode(result.Body)
        if response == true then
            print("Key Checker: Embedded API key is valid.")
            return true
        else
            warn("Key Checker: Embedded API key is invalid.")
            return false
        end
    else
        warn("Key Checker: Error checking API Key:", result)
        return false
    end
end
