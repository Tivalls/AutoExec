-- Generic Billboard ESP Function Creator
local function CreateBillboardESPLogic(espKey, targetParentGetter, nameFilterFunction, defaultLabelPrefix, initialColor)
    local moduleState = { isEnabled = false, espColor = initialColor or Color3.new(1, 1, 1), trackedInstances = {}, mainConnections = {} }; Holder[espKey.."_State"] = moduleState

    local function internalCreateESP(modelInstance, labelText)
        if not modelInstance or not modelInstance.Parent or moduleState.trackedInstances[modelInstance] then return end
        local rootPart = modelInstance:FindFirstChild("HumanoidRootPart") or modelInstance:FindFirstChild("RootPart") or modelInstance:FindFirstChildOfClass("BasePart"); if not rootPart then return end
        local billboardGui = Instance.new("BillboardGui"); billboardGui.Name = espKey .. "_Billboard"; billboardGui.Adornee = rootPart; billboardGui.Size = UDim2.new(0, 150, 0, 40); billboardGui.StudsOffset = Vector3.new(0, 2, 0); billboardGui.AlwaysOnTop = true; billboardGui.LightInfluence = 0; billboardGui.Enabled = moduleState.isEnabled and Holder.GlobalESPEnabled; billboardGui.Parent = modelInstance
        local textLabel = Instance.new("TextLabel"); textLabel.Name = "ESPTag"; textLabel.Size = UDim2.new(1, 0, 1, 0); textLabel.BackgroundTransparency = 1; textLabel.TextColor3 = moduleState.espColor; textLabel.TextStrokeTransparency = 0.5; textLabel.TextStrokeColor3 = Color3.new(0,0,0); textLabel.Font = Enum.Font.SourceSansSemibold; textLabel.TextSize = 14; textLabel.Text = labelText; textLabel.Parent = billboardGui
        local rsConnection; rsConnection = RunService.RenderStepped:Connect(function() if not modelInstance or not modelInstance.Parent or not rootPart or not rootPart.Parent or not billboardGui or not billboardGui.Parent then if rsConnection then rsConnection:Disconnect() end; if moduleState.trackedInstances[modelInstance] then if moduleState.trackedInstances[modelInstance].gui and moduleState.trackedInstances[modelInstance].gui.Parent then moduleState.trackedInstances[modelInstance].gui:Destroy() end; moduleState.trackedInstances[modelInstance] = nil end; return end; local currentDistance = math.huge; local localPlayerChar = Players.LocalPlayer and Players.LocalPlayer.Character; if localPlayerChar and localPlayerChar:FindFirstChild("HumanoidRootPart") then currentDistance = (localPlayerChar.HumanoidRootPart.Position - rootPart.Position).Magnitude end; local isVisible = moduleState.isEnabled and Holder.GlobalESPEnabled and (currentDistance <= Holder.GlobalMaxDistance); billboardGui.Enabled = isVisible; if isVisible then if localPlayerChar then textLabel.Text = string.format("[%s] %.0fm", labelText, currentDistance) else textLabel.Text = string.format("[%s] [N/A]", labelText) end else textLabel.Text = "" end end); moduleState.trackedInstances[modelInstance] = {gui = billboardGui, rsConn = rsConnection}
    end

    local function internalToggleESP(enabled) moduleState.isEnabled = enabled; local effectiveGlobalEnable = Holder.GlobalESPEnabled; for model, data in pairs(moduleState.trackedInstances) do if data and data.gui and data.gui.Parent then data.gui.Enabled = moduleState.isEnabled and effectiveGlobalEnable else if data and data.rsConn and data.rsConn.Connected then data.rsConn:Disconnect() end; moduleState.trackedInstances[model] = nil end end; if moduleState.isEnabled and effectiveGlobalEnable then local targetParent = targetParentGetter(); if targetParent then for _, model in ipairs(targetParent:GetChildren()) do if model:IsA("Model") and nameFilterFunction(model) then if not moduleState.trackedInstances[model] then internalCreateESP(model, defaultLabelPrefix or model.Name) end end end end end end
    local function internalUpdateColor(color) moduleState.espColor = color; for model, data in pairs(moduleState.trackedInstances) do if data and data.gui and data.gui.Parent then local textLabel = data.gui:FindFirstChild("ESPTag"); if textLabel then textLabel.TextColor3 = moduleState.espColor end end end end
    local function cleanup() for model, data in pairs(moduleState.trackedInstances) do if data then if data.rsConn and data.rsConn.Connected then data.rsConn:Disconnect() end; if data.gui and data.gui.Parent then data.gui:Destroy() end end end; moduleState.trackedInstances = {}; for _, conn in ipairs(moduleState.mainConnections) do if conn.Connected then conn:Disconnect() end end; moduleState.mainConnections = {} end
    Holder[espKey] = { Toggle = internalToggleESP, UpdateColor = internalUpdateColor, Cleanup = cleanup, IsEnabled = function() return moduleState.isEnabled end }
    local targetParent = targetParentGetter(); if targetParent then local childAddedConn = targetParent.ChildAdded:Connect(function(model) if model:IsA("Model") and nameFilterFunction(model) then task.wait(0.1); internalCreateESP(model, defaultLabelPrefix or model.Name) end end); table.insert(moduleState.mainConnections, childAddedConn); for _, model in ipairs(targetParent:GetChildren()) do if model:IsA("Model") and nameFilterFunction(model) then internalCreateESP(model, defaultLabelPrefix or model.Name) end end else warn("Could not find target parent for ESP:", espKey) end
end

-- Create specific Billboard ESPs using the generic creator
CreateBillboardESPLogic("NPC_ESP", function() return workspace:FindFirstChild("NPCs") end, function(model) return model:FindFirstChild("Humanoid") and not string.match(model.Name, "^Shrine") and not string.match(model.Name, "^Mystic") end)
CreateBillboardESPLogic("Shrine_ESP", function() return workspace:FindFirstChild("NPCs") end, function(model) return string.match(model.Name, "^Shrine") and model:FindFirstChild("Humanoid") end)
CreateBillboardESPLogic("Mystic_ESP", function() return workspace:FindFirstChild("NPCs") end, function(model) return string.match(model.Name, "^Mystic") and model:FindFirstChild("Humanoid") end)
CreateBillboardESPLogic("Whirlpool_ESP", function() return workspace end, function(model) return model.Name == "DepthsWhirlpool" end)
CreateBillboardESPLogic("Chest_ESP", function() return workspace:FindFirstChild("Thrown") end, function(model) return true end, "Chest")

