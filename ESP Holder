            getgenv().textlabels_Line1_MobESP = getgenv().textlabels_Line1_MobESP or {}; getgenv().textlabels_Line2_MobESP = getgenv().textlabels_Line2_MobESP or {}; getgenv().Events_MobESP = getgenv().Events_MobESP or {}; getgenv().Lock_Create_MobESP = false; getgenv().mob_esp_rainbow = getgenv().mob_esp_rainbow == nil and false or getgenv().mob_esp_rainbow
