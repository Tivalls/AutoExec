            if workspace:FindFirstChild("Live") then getgenv().Events_MobESP["ChildAdded_EV"] = workspace.Live.ChildAdded:Connect(addinstance_to_renderlist_MobESP); getgenv().Events_MobESP["ChildRemoved_EV"] = workspace.Live.ChildRemoved:Connect(function(character_object) pcall(function() if getgenv().textlabels_Line1_MobESP[character_object] ~= nil then getgenv().textlabels_Line1_MobESP[character_object]:Remove(); getgenv().textlabels_Line1_MobESP[character_object] = nil; getgenv().textlabels_Line2_MobESP[character_object]:Remove(); getgenv().textlabels_Line2_MobESP[character_object] = nil end end) end); for _,character_object in pairs(workspace.Live:GetChildren()) do addinstance_to_renderlist_MobESP(character_object) end else warn("Mob ESP: workspace.Live not found.") end
            RunService:BindToRenderStep("ESP_Mob_V2_Holder", 201, function() pcall(function() local localPlayerChar = Players.LocalPlayer and Players.LocalPlayer.Character; local playerpos = localPlayerChar and localPlayerChar:FindFirstChild("HumanoidRootPart") and localPlayerChar.HumanoidRootPart.Position or workspace.CurrentCamera.CFrame.Position; for npc_model, renderobject1 in pairs(getgenv().textlabels_Line1_MobESP) do local renderobject2 = getgenv().textlabels_Line2_MobESP[npc_model]; if renderobject1 and renderobject2 and npc_model and npc_model.Parent then local part = npc_model:FindFirstChild("HumanoidRootPart") or npc_model:FindFirstChild("Torso") or npc_model:FindFirstChildOfClass("BasePart"); if part then local character_pos_cframe = part.CFrame; local pos_on_screen, in_fov = getgenv().worldpoint_to_viewpoint_MobESP(character_pos_cframe); local distance = (character_pos_cframe.Position - playerpos).Magnitude; local should_be_visible = getgenv().MobESPEnabledState and Holder.GlobalESPEnabled and in_fov and distance < Holder.GlobalMaxDistance; renderobject1.Visible = should_be_visible; renderobject2.Visible = should_be_visible; if should_be_visible then renderobject1.Position = pos_on_screen; renderobject2.Position = renderobject1.Position + Vector2.new(0, renderobject1.TextBounds.Y); local humanoid = npc_model:FindFirstChildOfClass("Humanoid"); if humanoid then renderobject1.Text = npc_model.Name; renderobject2.Text = string.format("[%.0fm] [%.0f/%.0f]", distance, humanoid.Health, humanoid.MaxHealth) else renderobject1.Text = npc_model.Name; renderobject2.Text = string.format("[%.0fm]", distance) end; local color = getgenv().mob_esp_rainbow and Color3.fromHSV(tick()*0.1 % 1, 1, 1) or Color3.new(1,0.2,0.2); renderobject1.Color = color; renderobject2.Color = color; renderobject1.Size = 18; renderobject2.Size = 16 end else renderobject1.Visible = false; renderobject2.Visible = false end else if renderobject1 then renderobject1.Visible = false end; if renderobject2 then renderobject2.Visible = false end end end end) end)
            local last_cleaning_tick_mob_esp = tick(); getgenv().Events_MobESP["Cleaner_EV"] = RunService.Stepped:Connect(function() if tick() - last_cleaning_tick_mob_esp >= 5 then last_cleaning_tick_mob_esp = tick(); pcall(function() for npc_model, ro1 in pairs(getgenv().textlabels_Line1_MobESP) do if not npc_model or not npc_model.Parent then if ro1 then ro1:Remove() end; local ro2 = getgenv().textlabels_Line2_MobESP[npc_model]; if ro2 then ro2:Remove() end; getgenv().textlabels_Line1_MobESP[npc_model] = nil; getgenv().textlabels_Line2_MobESP[npc_model] = nil end end end) end end)
        end)
        if not s_init then warn("Mob ESP Initialization Error:", err_init) end
        getgenv().MobESPInitialized = true
    end

    Holder.ToggleMobESP = function(value) if not getgenv().MobESPInitialized then initializeMobESP() end; getgenv().MobESPEnabledState = value; if not value or not Holder.GlobalESPEnabled then if getgenv().textlabels_Line1_MobESP then for _, ro in pairs(getgenv().textlabels_Line1_MobESP) do if ro then ro.Visible = false end end end; if getgenv().textlabels_Line2_MobESP then for _, ro in pairs(getgenv().textlabels_Line2_MobESP) do if ro then ro.Visible = false end end end end
