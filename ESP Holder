-- Assume 'Tabs.Main' is correctly defined by your UI library earlier in your script.
-- local Tabs = ...
-- local LeftGroupBox = Tabs.Main:AddLeftGroupbox('SomeInitialGroupbox') -- Example

local ESP_Holder_Functions = nil -- Initialize as nil
local success, result = pcall(function()
    local fetchedScript = game:HttpGet("https://raw.githubusercontent.com/Tivalls/AutoExec/refs/heads/main/ESP%20Holder", true) -- Use true to ignore cache if possible
    if fetchedScript then
        local loadedFunc = loadstring(fetchedScript)
        if loadedFunc then
            -- Execute the loaded function to get the Holder table
            return loadedFunc()
        else
            warn("ESP Loader: loadstring failed to compile the fetched script.")
            return nil
        end
    else
        warn("ESP Loader: game:HttpGet failed to fetch the script.")
        return nil
    end
end)

if success and result and type(result) == "table" then
    ESP_Holder_Functions = result -- Assign the successfully returned table
    warn("ESP Holder script loaded successfully.")

    -- Optionally print keys to verify content (for debugging)
    -- print("ESP Holder Functions Keys:")
    -- for key, _ in pairs(ESP_Holder_Functions) do
    --     print("- " .. key)
    -- end

    -- Main ESP Controls
    local mainEspSettingsGroup = Tabs.Main:AddLeftGroupbox("Global ESP Settings")
    if type(ESP_Holder_Functions.SetGlobalESPEnable) == "function" then
        mainEspSettingsGroup:AddToggle("MainESP_Toggle", {
            Text = "Master ESP Toggle",
            Default = ESP_Holder_Functions.GlobalESPEnabled,
            Callback = function(value) ESP_Holder_Functions.SetGlobalESPEnable(value) end
        })
    else warn("Global ESP Toggle function (SetGlobalESPEnable) not found.") end

    if type(ESP_Holder_Functions.SetGlobalMaxDistance) == "function" then
        mainEspSettingsGroup:AddSlider("MainESP_Distance", {
            Text = "Max ESP Distance", Default = ESP_Holder_Functions.GlobalMaxDistance, Min = 50, Max = 2000, Suffix = "m",
            Callback = function(value) ESP_Holder_Functions.SetGlobalMaxDistance(value) end
        })
    else warn("Global ESP Max Distance function (SetGlobalMaxDistance) not found.") end

    -- Player ESP
    local playerEspGroup = Tabs.Main:AddLeftGroupbox('Player ESP')
    if type(ESP_Holder_Functions.TogglePlayerESP) == "function" then
        playerEspGroup:AddToggle('PlayerESP_Toggle', {
            Text = 'Enable Player ESP', Default = false,
            Callback = function(Value) ESP_Holder_Functions.TogglePlayerESP(Value) end
        })
    else warn("TogglePlayerESP function not found.") end

    if type(ESP_Holder_Functions.SetPlayerESPShowTeam) == "function" then
        playerEspGroup:AddToggle('PlayerESP_ShowTeam', {
            Text = 'Show Team Color', Default = false,
            Callback = function(Value) ESP_Holder_Functions.SetPlayerESPShowTeam(Value) end
        })
    else warn("SetPlayerESPShowTeam function not found.") end

    -- Mob ESP
    local mobEspGroup = Tabs.Main:AddLeftGroupbox('Mob ESP')
    if type(ESP_Holder_Functions.ToggleMobESP) == "function" then
        mobEspGroup:AddToggle('MobESP_Toggle', {
            Text = 'Enable Mob ESP', Default = false,
            Callback = function(Value) ESP_Holder_Functions.ToggleMobESP(Value) end
        })
    else warn("ToggleMobESP function not found.") end

    if type(ESP_Holder_Functions.SetMobESPRainbow) == "function" then
        mobEspGroup:AddToggle('MobESP_Rainbow', {
            Text = 'Rainbow Mob ESP', Default = false,
            Callback = function(Value) ESP_Holder_Functions.SetMobESPRainbow(Value) end
        })
    else warn("SetMobESPRainbow function not found.") end

    -- Function to create toggles for Generic Billboard ESPs
    local function CreateGenericESPToggles(groupParent, espKey, espLabel, defaultColor)
        local module = ESP_Holder_Functions[espKey]
        if module and type(module) == "table" then
            if type(module.Toggle) == "function" and type(module.UpdateColor) == "function" then
                groupParent:AddToggle(espKey .. "_Toggle", {
                    Text = "Enable " .. espLabel, Default = false,
                    Callback = function(Value) module.Toggle(Value) end
                }):AddColorPicker(espKey .. "_Color", {
                    Default = defaultColor or Color3.new(1,1,1), Title = espLabel .. " Color",
                    Callback = function(color) module.UpdateColor(color) end
                })
            else warn("ESP Module '" .. espKey .. "' is missing .Toggle or .UpdateColor function.") end
        else warn("ESP Module not found in Holder or is not a table:", espKey) end
    end

    local npcGroup = Tabs.Main:AddLeftGroupbox("NPCs ESP")
    CreateGenericESPToggles(npcGroup, "NPC_ESP", "Regular NPC ESP")
    CreateGenericESPToggles(npcGroup, "Shrine_ESP", "Shrine ESP")
    CreateGenericESPToggles(npcGroup, "Mystic_ESP", "Mystic ESP")

    local worldObjGroup = Tabs.Main:AddLeftGroupbox("World Objects ESP")
    CreateGenericESPToggles(worldObjGroup, "Whirlpool_ESP", "Whirlpool ESP")
    CreateGenericESPToggles(worldObjGroup, "Chest_ESP", "Chest ESP")

else
    -- Loading failed, print the error message
    warn("Failed to load or execute ESP Holder script. Error: ", result)
    warn("ESP_Holder_Functions is nil or not a table. Type: " .. type(result))
end
