--[[
    ESP Holder Script (v3 - Removed unwanted ESP types & prints)
    Hosted and loaded via loadstring(game:HttpGet(...))()
    Returns a table of functions to control ESPs.
]]

local Holder = {}
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService") -- For global click if needed

--// Global ESP Settings (Defaults) \\--
Holder.GlobalESPEnabled = true
Holder.GlobalMaxDistance = 500 -- Default global max distance for all ESPs
-- Holder.Is2DESPMode = false -- REMOVED 2D ESP

--// Global Control Functions \\--
Holder.SetGlobalESPEnable = function(value)
    Holder.GlobalESPEnabled = value
    -- Trigger a refresh/re-evaluation for all active ESPs
    for key, module in pairs(Holder) do
        if type(module) == "table" and module.Toggle and type(module.IsEnabled) == "function" then
            module.Toggle(module.IsEnabled()) -- Re-call toggle to apply global state
        elseif key == "TogglePlayerESP" and Holder.PlayerESPState then
             Holder.TogglePlayerESP(Holder.PlayerESPState.isEnabled)
        elseif key == "ToggleMobESP" and getgenv().MobESPInitialized then
             Holder.ToggleMobESP(getgenv().MobESPEnabledState) -- Use state var
        end
    end
end

Holder.SetGlobalMaxDistance = function(value)
    Holder.GlobalMaxDistance = tonumber(value) or 500
    -- Individual ESPs will read this in their RenderStepped
end

-- REMOVED Set2DESPMode function

-- Player ESP Module
do
    Holder.PlayerESPState = { isEnabled = false, showTeam = false }
    local heartbeatConnection = nil
    local playerGuis = {}

    local function cleanupAllPlayerESP()
        if heartbeatConnection then heartbeatConnection:Disconnect(); heartbeatConnection = nil; end
        for p, gui in pairs(playerGuis) do if gui and gui.Parent then gui:Destroy() end end
        playerGuis = {}
        for _, player in ipairs(Players:GetPlayers()) do if player.Character and player.Character:FindFirstChild("Head") then local oldGui = player.Character.Head:FindFirstChild("TadachiisESPTags_Holder_V2"); if oldGui then oldGui:Destroy() end end end
    end

    local function updatePlayerESP()
        if not Holder.PlayerESPState.isEnabled or not Holder.GlobalESPEnabled then return end
        local localPlayer = Players.LocalPlayer; local localCharacter = localPlayer and localPlayer.Character; if not localCharacter or not localCharacter:FindFirstChild("Head") then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer and player.Character and player.Character:FindFirstChild("Head") then
                local head = player.Character.Head; local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if not humanoid then if playerGuis[player] then playerGuis[player]:Destroy(); playerGuis[player] = nil; end continue end
                local distance = (localCharacter.Head.Position - head.Position).Magnitude
                if distance > Holder.GlobalMaxDistance then if playerGuis[player] then playerGuis[player].Enabled = false; end; continue; end
                local currentHealth = math.floor(humanoid.Health); local maxHealth = math.floor(humanoid.MaxHealth)
                local billboardGui = playerGuis[player] or head:FindFirstChild("TadachiisESPTags_Holder_V2")
                if not billboardGui then billboardGui = Instance.new("BillboardGui"); billboardGui.Name = "TadachiisESPTags_Holder_V2"; billboardGui.Adornee = head; billboardGui.Size = UDim2.new(0, 120, 0, 60); billboardGui.StudsOffset = Vector3.new(0, 2.7, 0); billboardGui.AlwaysOnTop = true; billboardGui.LightInfluence = 0; billboardGui.Parent = head; playerGuis[player] = billboardGui; local textLabel = Instance.new("TextLabel"); textLabel.Name = "NameLabel"; textLabel.Size = UDim2.new(1, 0, 1, 0); textLabel.BackgroundTransparency = 1; textLabel.Font = Enum.Font.SourceSansSemibold; textLabel.TextScaled = false; textLabel.TextSize = 14; textLabel.TextStrokeColor3 = Color3.new(0,0,0); textLabel.TextStrokeTransparency = 0.5; textLabel.Parent = billboardGui end
                billboardGui.Enabled = Holder.PlayerESPState.isEnabled and Holder.GlobalESPEnabled; local nameLabel = billboardGui:FindFirstChild("NameLabel")
                if nameLabel then local teamColor = player.Team and player.Team.TeamColor.Color or Color3.new(1, 0.2, 0.2); nameLabel.TextColor3 = Holder.PlayerESPState.showTeam and teamColor or Color3.new(1, 0.2, 0.2); local teamText = Holder.PlayerESPState.showTeam and (player.Team and " ["..player.Team.Name.."]" or "") or ""; nameLabel.Text = player.Name .. teamText .. "\n" .. math.floor(distance) .. "m\nHP: " .. currentHealth .. "/" .. maxHealth end
            else if playerGuis[player] then playerGuis[player]:Destroy(); playerGuis[player] = nil; end end
        end
    end

    Holder.TogglePlayerESP = function(value) Holder.PlayerESPState.isEnabled = value; if Holder.PlayerESPState.isEnabled and Holder.GlobalESPEnabled then if not heartbeatConnection or not heartbeatConnection.Connected then heartbeatConnection = RunService.Heartbeat:Connect(updatePlayerESP) end; updatePlayerESP() else for p, gui in pairs(playerGuis) do if gui and gui.Parent then gui.Enabled = false; end end; if not Holder.PlayerESPState.isEnabled then cleanupAllPlayerESP() end end end
    Holder.SetPlayerESPShowTeam = function(value) Holder.PlayerESPState.showTeam = value; if Holder.PlayerESPState.isEnabled and Holder.GlobalESPEnabled then updatePlayerESP(); end end
    Holder.CleanupPlayerESP = cleanupAllPlayerESP
end


-- Mob ESP Module (Syn Drawing based)
