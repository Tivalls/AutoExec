    getgenv().MobESPInitialized = getgenv().MobESPInitialized == nil and false or getgenv().MobESPInitialized

    local function initializeMobESP()
        if getgenv().MobESPInitialized then return end
        local s_init, err_init = pcall(function()
            function getgenv().synTextLabel_MobESP() local TextLabel = Drawing.new("Text"); if not getgenv().Syn_Drawing_MobESP then getgenv().Syn_Drawing_MobESP = {} end; table.insert(getgenv().Syn_Drawing_MobESP, TextLabel); TextLabel.Text = "Placeholder"; TextLabel.Size = 18; TextLabel.Center = true; TextLabel.Outline = true; TextLabel.Color = Color3.new(1, 0, 0); TextLabel.OutlineColor = Color3.new(0, 0, 0); return TextLabel end
