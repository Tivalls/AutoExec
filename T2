-- Roblox Luau Loader Script (Wave Executor Version - With Chat Monitor & Blacklist Call)

--[[ ======================= Configuration ======================= ]]
local script_key = "YOUR_API_KEY_HERE" -- <-- PASTE YOUR API KEY
local TARGET_SCRIPT_URL = "https://raw.githubusercontent.com/Tivalls/AutoExec/refs/heads/main/Dev"
-- !! NEW !! Base URL for YOUR external API endpoint
local AUTH_API_BASE_URL = "YOUR_API_ENDPOINT_BASE_URL_HERE" -- e.g., "https://your-function-url.cloudfunctions.net" or your server URL
--[[ ============================================================= ]]

-- Services
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui") -- For chat monitoring
local RunService = game:GetService("RunService") -- For IsStudio check (less relevant for executor)

-- Function to print messages
local function logMessage(message)
    print("[LOADER] " .. message)
end

-- Basic Input Validation
if not script_key or script_key == "" then logMessage("Error: script_key empty.") return end
if AUTH_API_BASE_URL == "YOUR_API_ENDPOINT_BASE_URL_HERE" then logMessage("Error: Auth API endpoint not configured.") return end

-- Get HWID (Ensure gethwid() exists in your executor)
local currentHwid = nil
local getHwidSuccess, hwidResult = pcall(gethwid)
if getHwidSuccess and type(hwidResult) == "string" and hwidResult ~= "" then
    currentHwid = hwidResult
    logMessage("HWID Retrieved: " .. currentHwid)
else
    logMessage("Error retrieving HWID.")
    warn("[LOADER] HWID Error:", hwidResult)
    local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nCould not retrieve required HWID.") end
    return
end

logMessage("Attempting authentication via API...")

-- Call YOUR external API for validation AND HWID check
local validationUrl = AUTH_API_BASE_URL .. "/validate" -- Example validation endpoint path
local validationPayload = HttpService:JSONEncode({ key = script_key, hwid = currentHwid })
local validationSuccess, validationResponseData = pcall(function()
    return request({ -- Wave's request function
        Url = validationUrl,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = validationPayload
    })
end)

if not validationSuccess then
    logMessage("Error: Network request to Auth API failed.")
    warn("[LOADER] Network Error Details:", validationResponseData)
    local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nAuth server network error.") end
    return
end

-- Process Validation Response
if validationResponseData.Success then
    local statusData = nil
    local decodeSuccess = pcall(function() statusData = HttpService:JSONDecode(validationResponseData.Body) end)

    if decodeSuccess and statusData and statusData.status then
        local status = statusData.status

        if status == "VALID" then
            logMessage("Authentication successful!")

            -- --- Chat Monitoring & Auto-Blacklist ---
            local monitorActive = true -- Flag to stop monitoring if needed
            local flaggedWords = {
                -- Clipping related (lowercase is fine, check ignores case)
                "clipped", "cl!pped", "cl1pped", "cl1pp3d", "cl!pp3d",
                "clip", "cl!p", "cl1p", "c!ip", "c1ip",
                "clipping",
        
                -- Exploiting/Hacking/Cheating related
                "exploit", "exploiter", "exploiting", "expl0it", "expl0iter", "expl0iting",
                "hack", "hacker", "hacking", "hax", "haxor", "haxxer", "h4x", "h4cker", "h4cking",
                "cheat", "cheater", "cheating", "ch3at", "ch3ater", "ch3ating",
                "mod", "modder", "modding", -- (Use with caution, 'mod' can be legit)
                "script", "scripter", "scripting", -- (Use with caution)
                "skid", -- Slang for script user
        
                -- Framing/Accusation related (Higher risk of false positives)
                "he exploits", "shes exploiting", "theyre exploiting",
                "is hacking", "are hacking",
                "using cheats",
                "hes cheating", "shes cheating",
                "i have proof", "got proof" -- Context dependent, risky
                -- Add more phrases like "[username] exploits", etc. if needed, but simple find() is limited
            }
            local webhook_url = "https://discord.com/api/webhooks/1325735244942409809/CMVN3_2Cpi92tSlT9O_bLdv_GZrWvYkY2nOTTQigIuJDC4BCg7CEA-UB_9JDWGGlKys_" -- Your webhook

            local function sendAndBlacklist(flaggedMessage)
                if not monitorActive then return end
                monitorActive = false -- Prevent multiple triggers

                logMessage("Flagged word detected! Sending notification and blacklist request.")

                local localPlayer = Players.LocalPlayer
                local hwid = currentHwid -- Use HWID already retrieved
                local username = localPlayer and localPlayer.Name or "Unknown Player"
                local date = os.date("%Y-%m-%d")
                local time = os.date("%H:%M:%S")

                -- 1. Send Webhook Notification
                local notificationData = {
                     ["content"] = "**Automatic Key Blacklist Triggered**",
                     ["embeds"] = { {
                         ["title"] = "Blacklist Details (Flagged Word)",
                         ["fields"] = {
                              {["name"] = "Username", ["value"] = username, ["inline"] = true},
                              {["name"] = "Used Key", ["value"] = "`"..script_key.."`", ["inline"] = false},
                              {["name"] = "Flagged Message", ["value"] = "||"..flaggedMessage.."||", ["inline"] = false}, -- Use spoiler
                              {["name"] = "Date", ["value"] = date, ["inline"] = true},
                              {["name"] = "Time", ["value"] = time, ["inline"] = true},
                              {["name"] = "HWID", ["value"] = hwid, ["inline"] = false}
                         },
                         ["color"] = 16711680 -- Red
                     } }
                 }
                 pcall(function()
                    request({Url = webhook_url, Method = "POST", Headers = {["Content-Type"]="application/json"}, Body = HttpService:JSONEncode(notificationData)})
                 end)

                 -- 2. Send Blacklist Request to YOUR API
                 local blacklistUrl = AUTH_API_BASE_URL .. "/blacklist" -- Example blacklist endpoint
                 local blacklistPayload = HttpService:JSONEncode({ key = script_key, reason = "Flagged word detected in chat: " .. flaggedMessage })

                 local blacklistSuccess, blacklistResponse = pcall(function()
                     return request({
                         Url = blacklistUrl,
                         Method = "POST",
                         Headers = {["Content-Type"] = "application/json"},
                         Body = blacklistPayload
                     })
                 end)

                 if blacklistSuccess then
                      logMessage("Blacklist request sent to API.")
                      warn("API Response:", blacklistResponse) -- Log API response for debugging
                 else
                      logMessage("Error sending blacklist request to API.")
                      warn("Blacklist API Error:", blacklistResponse)
                 end

                 -- 3. Kick Player (regardless of API success, kick on detection)
                 if localPlayer then
                    localPlayer:Kick("Zyg Hub [V3]\nKicked for using flagged language. Your key has been blacklisted.")
                 end
            end

            -- Connect to the Chatted event
            local chatConnection = Players.LocalPlayer.Chatted:Connect(function(message)
                if not monitorActive then return end
                for _, word in ipairs(flaggedWords) do
                    if message:lower():find(word:lower()) then
                        sendAndBlacklist(message) -- Pass the message for context
                        break -- Stop checking other words once one is found
                    end
                end
            end)
            logMessage("Chat monitoring active.")
            -- Optional: Disconnect monitor later if needed: chatConnection:Disconnect()

            -- --- End Chat Monitoring ---

            -- --- Load Main Script ---
            logMessage("Loading main script...")
            local getMainScriptSuccess, mainScriptOrError = pcall(function() return game:HttpGet(TARGET_SCRIPT_URL, true) end)
            if getMainScriptSuccess and mainScriptOrError then
                 local loadScriptSuccess, loadError = pcall(loadstring(mainScriptOrError))
                 if loadScriptSuccess then logMessage("Main script executed.")
                 else logMessage("Error executing main script:"); warn("[LOADER] Loadstring Error:", loadError); local p = Players.LocalPlayer; if p then p:Kick("Zyg Hub [V3]\nScript execution error.") end end
            else logMessage("Error downloading main script:"); warn("[LOADER] HttpGet Error:", mainScriptOrError); local p = Players.LocalPlayer; if p then p:Kick("Zyg Hub [V3]\nScript download error.") end end
            -- --- End Load Main Script ---

        elseif status == "HWID_MISMATCH" then
            logMessage("Authentication failed: HWID Mismatch.")
            local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nScript access denied, There is a HWID assigned to this script already. If you wish to do so, reset your hwid.") end
        elseif status == "NOT_REDEEMED" then
             logMessage("Authentication failed: Key not redeemed.")
             local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nScript access denied, the api key you have tried to use isnt connected to a discord account.") end
        elseif status == "BLACKLISTED" then
             logMessage("Authentication failed: Key blacklisted.")
             local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nScript access denied: Your key is blacklisted.") end
        elseif status == "INVALID_KEY" then
             logMessage("Authentication failed: Invalid Key.")
             local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nScript access denied: Invalid API Key provided.") end
        else
             logMessage("Authentication failed: Unknown status from API: " .. status)
             local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nUnknown authentication error.") end
        end
    else
        logMessage("Authentication failed: Could not parse response from Auth API.")
        local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nInvalid response from auth server.") end
    end
else
    logMessage("Authentication failed: Auth API returned error status code: " .. responseData.StatusCode)
    local player = Players.LocalPlayer; if player then player:Kick("Zyg Hub [V3]\nAuth server error (Code: " .. responseData.StatusCode .. ").") end
end
