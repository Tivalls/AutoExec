local tweenService = game:GetService("TweenService")
local rotation = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.In, -1)

local tween = tweenService:Create(LoadingCircle, rotation, {Rotation = 360})
tween:Play()

task.wait(2)
Status.Visible = false
Status2.Visible = true

local startTime = tick()

if not isfolder("ZyghubAudio") then
    makefolder("ZyghubAudio")
end

local function createMessage(text)
    Status2.Text = text
end

if not isfile("ZyghubAudio/ModJoin.mp3") then
    writefile("ZyghubAudio/ModJoin.mp3", "")
    createMessage("Downloading ModJoin.mp3...")
else
    createMessage("ModJoin.mp3 already exists.")
end

task.wait(1)

if not isfile("ZyghubAudio/ModLeave.mp3") then
    writefile("ZyghubAudio/ModLeave.mp3", "")
    createMessage("Downloading ModLeave.mp3...")
else
    createMessage("ModLeave.mp3 already exists.")
end

local downloadTime = tick() - startTime
task.wait(math.max(0, 3 - downloadTime)) -- Ensure minimum display time of 3 seconds

createMessage("Downloading Completed")
task.wait(1)

Status2.Visible = false
Status3.Visible = true

task.wait(2)
Status3.Text = "All Done"
task.wait(1)

